{
  "name": "@capacitor-community/contacts",
  "version": "7.0.5",
  "description": "Contacts Plugin for Capacitor",
  "main": "dist/plugin.cjs.js",
  "module": "dist/esm/index.js",
  "types": "dist/esm/index.d.ts",
  "unpkg": "dist/plugin.js",
  "files": [
    "android/src/main/",
    "dist/",
    "ios/Sources/",
    "Package.swift"
  ],
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/capacitor-community/contacts.git"
  },
  "bugs": {
    "url": "https://github.com/capacitor-community/contacts/issues"
  },
  "keywords": [
    "capacitor",
    "plugin"
  ],
  "scripts": {
    "verify": "npm run verify:ios && npm run verify:android && npm run verify:web",
    "verify:ios": "cd ios && pod install && xcodebuild -workspace Plugin.xcworkspace -scheme Plugin -destination generic/platform=iOS && cd ..",
    "verify:android": "cd android && ./gradlew clean build test && cd ..",
    "verify:web": "npm run build",
    "lint": "npm run eslint && npm run prettier -- --check && npm run swiftlint -- lint",
    "fmt": "npm run eslint -- --fix && npm run prettier -- --write && npm run swiftlint -- --fix --format",
    "eslint": "eslint . --ext ts",
    "prettier": "prettier \"**/*.{css,html,ts,js,java}\" --plugin=prettier-plugin-java --write",
    "swiftlint": "node-swiftlint",
    "docgen": "docgen --api ContactsPlugin --output-readme ./docs/api.md",
    "build": "npm run clean && npm run docgen && tsc && rollup -c rollup.config.mjs",
    "clean": "rimraf ./dist",
    "watch": "tsc --watch",
    "prepublishOnly": "npm run build",
    "release": "standard-version"
  },
  "devDependencies": {
    "@capacitor/android": "8.3.0",
    "@capacitor/core": "8.3.0",
    "@capacitor/ios": "8.3.0",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@ionic/eslint-config": "^0.4.0",
    "@ionic/prettier-config": "^4.0.0",
    "@ionic/swiftlint-config": "^2.0.0",
    "@tafelnl/capacitor-docgen": "^0.1.1",
    "@types/node": "^25.5.0",
    "eslint": "^10.1.0",
    "husky": "^9.1.7",
    "prettier": "^3.8.1",
    "prettier-plugin-java": "^2.8.1",
    "rimraf": "^6.1.3",
    "rollup": "^4.60.0",
    "standard-version": "^9.5.0",
    "swiftlint": "^2.0.0",
    "typescript": "^5.7.3"
  },
  "peerDependencies": {
    "@capacitor/core": ">=7.0.0"
  },
  "prettier": "@ionic/prettier-config",
  "swiftlint": "@ionic/swiftlint-config",
  "eslintConfig": {
    "extends": "@ionic/eslint-config/recommended"
  },
  "capacitor": {
    "ios": {
      "src": "ios"
    },
    "android": {
      "src": "android"
    }
  }
}